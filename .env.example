# AgentForge Environment Variables
# Copy this file to .env and fill in your keys

# --- LLM Providers ---
OPENAI_API_KEY=your_openai_key_here
GEMINI_API_KEY=your_gemini_key_here
GROQ_API_KEY=your_groq_key_here
OPENROUTER_API_KEY=your_openrouter_key_here

# --- Database ---
# Local SQLite fallback: sqlite+aiosqlite:///./agentforge.db
# Production PostgreSQL: postgresql+asyncpg://user:pass@localhost:5432/agentforge
#DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agentforge
DATABASE_URL=sqlite+aiosqlite:///./agentforge.db

# --- Security ---
# Secret key for JWT signing. Generate a strong one!
JWT_SECRET_KEY=yoursecretkeyhere

# --- Celery & Infra ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
CELERY_RESULT_BACKEND=redis://localhost:6379/1
